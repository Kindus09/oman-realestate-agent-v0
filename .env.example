# .env.example
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore so your secrets stay local.

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
# These are already set in config/settings.py.
# Uncomment and change here only if you want to override the defaults.

# CLAUDE_MODEL=claude-opus-4-6
# MAX_PAGES=5
# REQUEST_DELAY_MIN=2
# REQUEST_DELAY_MAX=3
